# .env.example

# ======================
# App (Environment)
# ======================
NODE_ENV=development
PORT=5000

APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:5000
APP_NAME=Mishkat Academy

# Secure Link (Nginx)
NGINX_SECURE_LINK_SECRET=your_secure_link_secret_here
NGINX_SECURE_LINK_TTL_SECONDS=600

# ======================
# Database
# ======================
MONGODB_URI=mongodb://username:password@127.0.0.1:27017/db_name?authSource=db_name

# ======================
# Auth (JWT)
# ======================
JWT_SECRET=your_jwt_secret_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_64_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ======================
# CORS
# ======================
# Comma-separated values OR *
CORS_ORIGINS=http://localhost:3000

# ======================
# Cookies
# ======================
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
TRUST_PROXY=false

# ======================
# Seed Admin (Optional)
# ======================
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=StrongPassword123!
SEED_ADMIN_FIRSTNAME=Admin
SEED_ADMIN_LASTNAME=User
SEED_ADMIN_VERIFY_EMAIL=true

SEED_ADMIN_UPDATE_NAME=true
SEED_ADMIN_RESET_PASSWORD=true

# ======================
# Rate Limit
# ======================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
GRACEFUL_TIMEOUT_MS=10000

# ======================
# Logging & Body
# ======================
JSON_BODY_LIMIT=2mb
UPLOAD_MAX_MB=10
LOG_LEVEL=info

# ======================
# Redis (Optional)
# ======================
REDIS_URL=

# ======================
# Payments (Moyasar)
# ======================
MOYASAR_API_KEY=your_moyasar_api_key
CURRENCY=SAR
MOYASAR_SUCCESS_URL=http://localhost:3000/pay/success
MOYASAR_FAIL_URL=http://localhost:3000/pay/fail
WEBHOOK_SECRET=your_webhook_secret

# ======================
# Orders
# ======================
VAT_PERCENT=15
SHIPPING_FLAT_HALALAS=0

# ======================
# Consultations
# ======================
CONSULTATION_HOLD_TTL_MINUTES=15
CONSULTATION_MIN_NOTICE_HOURS=24
CONSULTATION_MAX_ADVANCE_DAYS=30
CONSULTATION_BUFFER_MINUTES=10
CONSULTATION_CANCEL_WINDOW_HOURS=24

# ======================
# Emails (Resend)
# ======================
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=no-reply@example.com
RESEND_FROM_NAME="Your App Name"
