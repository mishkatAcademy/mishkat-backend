# .env.example
APP_NAME="Mishkat Academy"

# ======================
# App
# ======================
NODE_ENV=development
PORT=5000

# واجهة المستخدم (الفرونت)
APP_URL=http://localhost:3000

# عنوان السيرفر نفسه (لإنشاء روابط ثابتة للملفات المرفوعة مثل /uploads/...)
APP_BASE_URL=http://localhost:5000

# ======================
# Database (شكل موحّد)
# - للمحلي: mongodb://127.0.0.1:27017/<db>?directConnection=true
# - لـ Atlas: mongodb+srv://<user>:<pass>@cluster0.xxxx.mongodb.net/<db>
# ======================
MONGODB_URI=mongodb://127.0.0.1:27017/mishkat?directConnection=true

# ======================
# Auth (JWT)
# - غيّر الأسرار في الإنتاج لقيم عشوائية طويلة
# ======================
JWT_SECRET=change_me_to_32+_chars________________
REFRESH_TOKEN_SECRET=change_me_to_64+_chars________________________________________
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ======================
# CORS / Cookies / Proxy
# - لو عندك أكثر من أصل (origin) افصلهم بفواصل
# - للإنتاج مع cross-site cookies استخدم: COOKIE_SECURE=true و COOKIE_SAMESITE=none و TRUST_PROXY=true
# ======================
CORS_ORIGINS=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
TRUST_PROXY=false

# ======================
# Limits / Logging
# ======================
RATE_LIMIT_WINDOW_MS=900000
GRACEFUL_TIMEOUT_MS=10000
RATE_LIMIT_MAX=100
JSON_BODY_LIMIT=2mb
UPLOAD_MAX_MB=10
LOG_LEVEL=info

# ======================
# Redis (اختياري)
# - الصيغة: redis://[:password@]host:port
# ======================
REDIS_URL=

# ======================
# Payments (Moyasar)
# ======================
MOYASAR_API_KEY=
CURRENCY=SAR
MOYASAR_SUCCESS_URL=http://localhost:3000/pay/success
MOYASAR_FAIL_URL=http://localhost:3000/pay/fail
WEBHOOK_SECRET=

# ======================
# Order / Payments
# ======================
VAT_PERCENT=15
SHIPPING_FLAT_HALALAS=0

# ======================
# Consultations
# ======================
CONSULTATION_HOLD_TTL_MINUTES=15
CONSULTATION_MIN_NOTICE_HOURS=24
CONSULTATION_MAX_ADVANCE_DAYS=30
CONSULTATION_BUFFER_MINUTES=10
CONSULTATION_CANCEL_WINDOW_HOURS=24

# ======================
# Emails (Resend)
# ======================
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=no-reply@mishkat.academy
RESEND_FROM_NAME="Mishkat Academy"

# ======================
# ملاحظات الإنتاج (اقترحات)
# ======================
# NODE_ENV=production

# APP_URL=https://mishkat.academy          
# APP_BASE_URL=https://api.mishkat.academy  

# CORS_ORIGINS=https://mishkat.academy

# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
# TRUST_PROXY=true            

# LOG_LEVEL=info
# JSON_BODY_LIMIT=2mb
# UPLOAD_MAX_MB=10
